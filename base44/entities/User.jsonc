{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "is_premium": {
      "type": "boolean",
      "default": false,
      "description": "Whether the user has an active premium subscription"
    },
    "premium_since": {
      "type": "string",
      "format": "date",
      "description": "Date when premium was activated"
    }
  }
}